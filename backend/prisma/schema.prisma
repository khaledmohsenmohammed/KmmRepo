// KmmRepo Prisma schema.
// Phase 1, slice 1: User only. Project / Folder / TestCase / AuditLog etc.
// are added in later phases (see docs/DEVELOPMENT_GUIDE.md §7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  bio          String?
  avatarUrl    String?
  status       UserStatus @default(PENDING)
  globalRole   GlobalRole @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}
