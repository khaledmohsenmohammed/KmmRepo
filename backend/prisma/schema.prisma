// KmmRepo Prisma schema.
// Phase 1, slice 1: User only. Project / Folder / TestCase / AuditLog etc.
// are added in later phases (see docs/DEVELOPMENT_GUIDE.md §7).

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; debian-openssl-3.0.x for the node:20-slim container.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

// Per-project roles (DEVELOPMENT_GUIDE.md §7). Stored as assignment labels for now;
// permission enforcement per role is a planned follow-up ("permissions list").
enum ProjectRole {
  TEST_LEAD
  AUTOMATION_TESTER
  MANUAL_TESTER
  PENTESTER
  PROJECT_LEAD
}

enum TestCaseType {
  MANUAL
  AUTOMATION
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  bio          String?
  avatarUrl    String?
  // Profile avatar metadata (self-service profile management).
  avatarName        String?
  avatarDescription String?
  // Unique ref per upload: "<ISO date-time>-<random>" (e.g. 2026-06-17T10:22:31.000Z-48217).
  avatarRef         String?
  status       UserStatus @default(PENDING)
  globalRole   GlobalRole @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Soft delete (super-admin can restore). Never hard-delete users.
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  deletedBy    String?

  memberships  ProjectMembership[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft delete (super-admin can restore). Never hard-delete projects.
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  deletedBy   String?

  memberships ProjectMembership[]
  folders     Folder[]
  testCases   TestCase[]

  @@map("projects")
}

model Folder {
  id        String    @id @default(cuid())
  name      String
  projectId String
  parentId  String?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Soft delete (cascades to descendants in the service). Never hard-delete folders.
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  // Self-relation for the nested folder tree. Restrict so a hard delete can never
  // silently orphan/detach a subtree — the app only ever soft-deletes.
  parent    Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Folder[]  @relation("FolderTree")
  testCases TestCase[]

  @@index([projectId])
  @@index([parentId])
  @@map("folders")
}

model ProjectMembership {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole
  grantedBy String
  grantedAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id])
  project   Project     @relation(fields: [projectId], references: [id])

  // A user holds at most one role per project.
  @@unique([userId, projectId])
  @@map("project_memberships")
}

model TestCase {
  id            String       @id @default(cuid())
  projectId     String
  folderId      String
  title         String
  description   String?
  type          TestCaseType @default(MANUAL)
  playwrightRef String?
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedBy     String?
  updatedAt     DateTime     @updatedAt

  // Soft delete (steps stay, hidden with the case). Never hard-delete.
  isDeleted     Boolean      @default(false)
  deletedAt     DateTime?
  deletedBy     String?

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  folder        Folder       @relation(fields: [folderId], references: [id], onDelete: Restrict)
  steps         TestStep[]

  @@index([projectId])
  @@index([folderId])
  @@map("test_cases")
}

model TestStep {
  id         String   @id @default(cuid())
  testCaseId String
  order      Int
  action     String
  expected   String

  // Steps are wholly owned by the case (never soft-deleted or referenced on their
  // own), so Cascade is correct here — the one exception to the app's Restrict rule.
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@index([testCaseId])
  @@map("test_steps")
}
