// KmmRepo Prisma schema.
// Phase 1, slice 1: User only. Project / Folder / TestCase / AuditLog etc.
// are added in later phases (see docs/DEVELOPMENT_GUIDE.md §7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  bio          String?
  avatarUrl    String?
  // Profile avatar metadata (self-service profile management).
  avatarName        String?
  avatarDescription String?
  // Unique ref per upload: "<ISO date-time>-<random>" (e.g. 2026-06-17T10:22:31.000Z-48217).
  avatarRef         String?
  status       UserStatus @default(PENDING)
  globalRole   GlobalRole @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Soft delete (super-admin can restore). Never hard-delete users.
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  deletedBy    String?

  @@map("users")
}
