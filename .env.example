# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://kmmrepo:kmmrepo@localhost:5432/kmmrepo?schema=public"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT secrets (generate strong random values, e.g. openssl rand -hex 32) ──
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ── Seed super-admin (created by `npm run seed`) ──────────
SEED_SUPERADMIN_EMAIL="admin@kmmrepo.local"
SEED_SUPERADMIN_PASSWORD="ChangeMe!123"
SEED_SUPERADMIN_NAME="Super Admin"

# ── Server / CORS ─────────────────────────────────────────
PORT="4000"
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# ── Storage / AI (unused until later phases) ──────────────
# STORAGE_PATH="./storage"
# STORAGE_ENDPOINT=""
# AI_GATEWAY_URL=""
